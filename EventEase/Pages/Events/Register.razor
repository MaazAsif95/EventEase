@page "/events/{Id:guid}/register"
@using EventEase.Models
@using System.Linq.Expressions
@inject EventEase.Services.IEventService EventService
@inject NavigationManager Nav

<h3>Register for event</h3>

@if (loading)
{
    <p>Loading event...</p>
}
else if (eventModel == null)
{
    <p>Event not found.</p>
}
else
{
    <div class="card" style="max-width:600px;">
        <div class="card-body">
            <h4>@eventModel.Title</h4>
            <p>@eventModel.Date.ToString("f") — @eventModel.Location</p>

            <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="mb-2">
                    <label class="form-label">Name</label>
                    <InputText class="@FieldClass(() => registration.Name)" @bind-Value="registration.Name" />
                    <ValidationMessage For="@(() => registration.Name)" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Email</label>
                    <InputText class="@FieldClass(() => registration.Email)" @bind-Value="registration.Email" />
                    <ValidationMessage For="@(() => registration.Email)" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" type="submit">Submit</button>
                    <button class="btn btn-secondary" type="button" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    EventModel? eventModel;
    bool loading = true;

    RegistrationModel registration = new RegistrationModel();
    EditContext? editContext;

    protected override void OnInitialized()
    {
        editContext = new EditContext(registration);
        editContext.OnFieldChanged += (s, e) =>
        {
            editContext.Validate();
            StateHasChanged();
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadEventAsync();
    }

    async Task LoadEventAsync()
    {
        loading = true;
        try
        {
            eventModel = await EventService.GetEventAsync(Id);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    async Task HandleSubmit()
    {
        // validate again server-side (business rules)
        if (editContext != null && !editContext.Validate())
            return;

        // save registration
        registration.RegisteredAt = DateTime.Now;
        await EventService.AddRegistrationAsync(Id, registration);

        // navigate back to events list
        Nav.NavigateTo("/events");
    }

    void Cancel()
    {
        Nav.NavigateTo($"/events/{Id}/details");
    }

    string FieldClass<T>(Expression<Func<T>> accessor)
    {
        if (editContext == null) return "form-control";
        var field = FieldIdentifier.Create(accessor);
        var hasErrors = editContext.GetValidationMessages(field).Any();
        return hasErrors ? "form-control is-invalid" : "form-control";
    }
}
