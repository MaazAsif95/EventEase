@page "/events/{Id:guid}/details"
@using System.Text.Json
@using EventEase.Models
@using EventEase.Components
@inject EventEase.Services.IEventService EventService
@inject NavigationManager Nav

<h3>Event Details</h3>

@if (loading)
{
    <p>Loading...</p>
}
else if (eventModel == null)
{
    <p>Event not found.</p>
}
else
{
    <div>
        <EventCard @bind-EventData="eventModel" OnSaved="OnSaved" />
        <div class="mt-2">
            <small class="text-muted">Registrations: @registrationCount</small>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="Register">Register</button>
            <button class="btn btn-outline-primary" @onclick="ViewRegistrations">View registrations</button>
            <button class="btn btn-secondary" @onclick="Back">Back</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    EventModel? eventModel;
    bool loading = true;
    int registrationCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadEventAsync();
    }

    async Task LoadEventAsync()
    {
        loading = true;
        try
        {
            eventModel = await EventService.GetEventAsync(Id);
            var regs = await EventService.GetRegistrationsAsync(Id);
            registrationCount = regs?.Count ?? 0;
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    void Register()
    {
        Nav.NavigateTo($"/events/{Id}/register");
    }

    void Back()
    {
        Nav.NavigateTo("/events");
    }

    async Task OnSaved(EventModel model)
    {
        await EventService.SaveEventAsync(model);
        await LoadEventAsync();
    }

    void ViewRegistrations()
    {
        Nav.NavigateTo($"/events/{Id}/registrations");
    }
}
